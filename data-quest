<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DATA QUEST</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Rajdhani:wght@400;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a1628;
  --panel: #0d1f3c;
  --panel2: #0f2647;
  --border: #1a3a6b;
  --accent: #00d4ff;
  --accent2: #0080ff;
  --accent3: #00aaff;
  --gold: #00d4ff;
  --text: #e8f4fd;
  --muted: #4a6080;
  --correct: #39ff14;
  --wrong: #ff3366;
  --streak: #0099ff;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Rajdhani', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* Animated grid background */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* Glow orbs */
.orb {
  position: fixed;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  z-index: 0;
  opacity: 0.15;
}
.orb1 { width: 400px; height: 400px; background: #0055aa; top: -100px; left: -100px; animation: orbMove1 12s ease-in-out infinite; }
.orb2 { width: 300px; height: 300px; background: #00aaff; bottom: -80px; right: -80px; animation: orbMove2 10s ease-in-out infinite; }
.orb3 { width: 200px; height: 200px; background: #0066cc; top: 50%; right: 20%; animation: orbMove3 8s ease-in-out infinite; }
@keyframes orbMove1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(60px,40px)} }
@keyframes orbMove2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-40px,-60px)} }
@keyframes orbMove3 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(30px,-30px)} }

.game-container {
  position: relative;
  z-index: 1;
  max-width: 820px;
  margin: 0 auto;
  padding: 20px 16px 40px;
}

/* ── HEADER ── */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  flex-wrap: wrap;
  gap: 12px;
}
.logo {
  font-family: 'Orbitron', monospace;
  font-size: clamp(1.6rem, 5vw, 2.4rem);
  font-weight: 900;
  color: #00d4ff;
  text-shadow: 0 0 20px rgba(0,212,255,0.6), 0 0 40px rgba(0,150,255,0.4);
  letter-spacing: 3px;
}
.logo span { color: var(--accent2); }

/* ── STATS BAR ── */
.stats-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.stat-chip {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Orbitron', monospace;
  font-size: 0.85rem;
  font-weight: 700;
  position: relative;
  overflow: hidden;
}
.stat-chip::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}
.stat-chip.pts::before { background: #00d4ff; }
.stat-chip.str::before { background: #0099ff; }
.stat-chip.prg::before { background: var(--accent); }
.stat-chip .val { font-size: 1.1rem; }
.stat-chip.pts .val { color: var(--gold); }
.stat-chip.str .val { color: var(--streak); }
.stat-chip.prg .val { color: var(--accent); }
.stat-label { color: var(--muted); font-size: 0.7rem; letter-spacing: 1px; }

/* ── TOPIC SELECTOR ── */
#topicScreen {
  text-align: center;
  padding: 40px 0;
}
.screen-title {
  font-family: 'Orbitron', monospace;
  font-size: clamp(1.1rem, 3vw, 1.6rem);
  color: var(--accent);
  letter-spacing: 4px;
  margin-bottom: 8px;
  text-transform: uppercase;
}
.screen-sub {
  color: var(--muted);
  font-size: 1.1rem;
  margin-bottom: 36px;
  font-family: 'Rajdhani', sans-serif;
  font-weight: 600;
  letter-spacing: 1px;
}
.topic-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
  margin-bottom: 20px;
}
.topic-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 28px 20px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.topic-card::after {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.2s;
  border-radius: 16px;
}
.topic-card.yt::after { background: radial-gradient(ellipse at center, rgba(0,170,255,0.18), transparent 70%); }
.topic-card.f1::after { background: radial-gradient(ellipse at center, rgba(0,120,255,0.18), transparent 70%); }
.topic-card.sonic::after { background: radial-gradient(ellipse at center, rgba(0,200,255,0.18), transparent 70%); }
.topic-card:hover { transform: translateY(-4px); border-color: var(--accent); }
.topic-card:hover::after { opacity: 1; }
.topic-card:hover .topic-icon { transform: scale(1.15); }
.topic-icon { font-size: 3.5rem; margin-bottom: 12px; display: block; transition: transform 0.2s; }
.topic-name {
  font-family: 'Orbitron', monospace;
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 6px;
  letter-spacing: 1px;
}
.topic-desc { color: var(--muted); font-size: 0.95rem; font-weight: 600; }
.topic-badge {
  position: absolute;
  top: 12px; right: 12px;
  background: var(--panel2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 3px 8px;
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  color: var(--muted);
}

/* ── QUESTION SCREEN ── */
#questionScreen { display: none; }

.q-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
  flex-wrap: wrap;
  gap: 8px;
}
.topic-tag {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 14px;
  font-family: 'Orbitron', monospace;
  font-size: 0.75rem;
  color: var(--accent);
  letter-spacing: 2px;
}
.q-counter {
  font-family: 'Space Mono', monospace;
  font-size: 0.85rem;
  color: var(--muted);
}
.q-type-badge {
  background: var(--panel2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 4px 10px;
  font-family: 'Orbitron', monospace;
  font-size: 0.65rem;
  color: var(--accent2);
  letter-spacing: 2px;
  text-transform: uppercase;
}

/* Progress strip */
.progress-strip {
  height: 4px;
  background: var(--panel);
  border-radius: 2px;
  margin-bottom: 20px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0066cc, #00d4ff);
  border-radius: 2px;
  transition: width 0.5s ease;
  box-shadow: 0 0 8px #00d4ff;
}

/* Q dots */
.q-dots {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}
.q-dot {
  width: 12px; height: 12px;
  border-radius: 3px;
  background: var(--panel2);
  border: 1px solid var(--border);
  transition: all 0.3s;
}
.q-dot.active { background: #00d4ff; box-shadow: 0 0 6px #00d4ff; border-color: #00d4ff; }
.q-dot.done-ok { background: var(--correct); border-color: var(--correct); }
.q-dot.done-bad { background: var(--wrong); border-color: var(--wrong); }

/* Main card */
.q-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 28px;
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
}
.q-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent3));
}

.q-text {
  font-size: clamp(1.05rem, 2.5vw, 1.3rem);
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 22px;
  color: var(--text);
  letter-spacing: 0.3px;
}

/* ── CHART AREA ── */
.chart-wrap {
  background: var(--panel2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 22px;
}
.chart-title {
  font-family: 'Space Mono', monospace;
  font-size: 0.75rem;
  color: #00d4ff;
  letter-spacing: 2px;
  margin-bottom: 16px;
  text-transform: uppercase;
}
.bar-chart { display: flex; flex-direction: column; gap: 10px; }
.bar-row {
  display: grid;
  grid-template-columns: 140px 1fr 48px;
  align-items: center;
  gap: 10px;
}
.bar-label {
  font-family: 'Rajdhani', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.bar-track {
  background: var(--bg);
  border-radius: 4px;
  height: 22px;
  overflow: hidden;
  border: 1px solid var(--border);
}
.bar-fill {
  height: 100%;
  border-radius: 4px;
  position: relative;
  transition: width 1s cubic-bezier(0.4,0,0.2,1);
  display: flex;
  align-items: center;
}
.bar-val {
  font-family: 'Space Mono', monospace;
  font-size: 0.8rem;
  color: var(--muted);
  text-align: right;
}

/* Pie chart */
.pie-wrap {
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}
.pie-svg { flex-shrink: 0; }
.pie-legend { display: flex; flex-direction: column; gap: 8px; }
.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  font-weight: 600;
}
.legend-dot { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; }

/* Line chart */
.line-chart-wrap { position: relative; }
.line-svg { width: 100%; height: 140px; overflow: visible; }

/* ── ANSWERS ── */
.answers-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
@media(max-width: 500px) { .answers-grid { grid-template-columns: 1fr; } }

.ans-btn {
  background: var(--panel2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 18px;
  text-align: left;
  cursor: pointer;
  transition: all 0.15s;
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: 'Rajdhani', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text);
  -webkit-tap-highlight-color: transparent;
  position: relative;
  overflow: hidden;
}
.ans-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.15s;
}
.ans-btn:hover:not(:disabled)::before { opacity: 1; background: rgba(0,212,255,0.05); }
.ans-btn:hover:not(:disabled) { border-color: var(--accent); transform: translateX(3px); }
.ans-btn:active:not(:disabled) { transform: scale(0.98); }
.ans-btn:disabled { cursor: default; }
.ans-letter {
  width: 28px; height: 28px;
  border-radius: 6px;
  background: var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Orbitron', monospace;
  font-size: 0.75rem;
  flex-shrink: 0;
  transition: background 0.2s;
}
.ans-btn.correct-ans {
  border-color: var(--correct);
  background: rgba(57,255,20,0.08);
  animation: correctFlash 0.5s ease;
}
.ans-btn.correct-ans .ans-letter { background: var(--correct); color: #000; }
.ans-btn.wrong-ans {
  border-color: var(--wrong);
  background: rgba(255,51,102,0.08);
  animation: wrongShake 0.4s ease;
}
.ans-btn.wrong-ans .ans-letter { background: var(--wrong); color: #fff; }
@keyframes correctFlash {
  0%{transform:scale(1)} 40%{transform:scale(1.03)} 100%{transform:scale(1)}
}
@keyframes wrongShake {
  0%,100%{transform:translateX(0)} 25%{transform:translateX(-6px)} 75%{transform:translateX(6px)}
}

/* ── FEEDBACK BAR ── */
.feedback-bar {
  border-radius: 10px;
  padding: 12px 18px;
  font-family: 'Rajdhani', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  margin-top: 12px;
  opacity: 0;
  transition: opacity 0.3s;
  display: flex;
  align-items: center;
  gap: 10px;
  letter-spacing: 0.5px;
}
.feedback-bar.show { opacity: 1; }
.feedback-bar.ok { background: rgba(57,255,20,0.1); border: 1px solid var(--correct); color: var(--correct); }
.feedback-bar.bad { background: rgba(255,51,102,0.1); border: 1px solid var(--wrong); color: var(--wrong); }
.feedback-bar .fb-detail { color: var(--muted); font-size: 0.9rem; margin-top: 2px; }

/* ── STREAK BANNER ── */
.streak-banner {
  position: fixed;
  top: 20px;
  left: 50%;
  transform: translateX(-50%) translateY(-80px);
  background: linear-gradient(135deg, #0055cc, #0088ff);
  border-radius: 50px;
  padding: 12px 28px;
  font-family: 'Orbitron', monospace;
  font-size: 1rem;
  font-weight: 700;
  color: white;
  z-index: 200;
  box-shadow: 0 4px 30px rgba(0,136,255,0.5);
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
  white-space: nowrap;
}
.streak-banner.show { transform: translateX(-50%) translateY(0); }

/* ── BUTTONS ── */
.btn-restart {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 20px;
  font-family: 'Orbitron', monospace;
  font-size: 0.75rem;
  color: var(--muted);
  cursor: pointer;
  letter-spacing: 2px;
  transition: all 0.2s;
  -webkit-tap-highlight-color: transparent;
}
.btn-restart:hover { border-color: var(--accent); color: var(--accent); }

/* ── COMPLETE SCREEN ── */
#completeScreen {
  display: none;
  text-align: center;
  padding: 40px 20px;
}
#completeScreen.show { display: block; }
.complete-icon { font-size: 5rem; margin-bottom: 16px; animation: trophyBounce 1s ease infinite alternate; }
@keyframes trophyBounce { from{transform:translateY(0) rotate(-5deg)} to{transform:translateY(-16px) rotate(5deg)} }
.complete-title {
  font-family: 'Orbitron', monospace;
  font-size: clamp(1.5rem, 5vw, 2.5rem);
  font-weight: 900;
  color: #00d4ff;
  text-shadow: 0 0 20px rgba(0,212,255,0.5);
  margin-bottom: 8px;
  letter-spacing: 3px;
}
.complete-sub { color: var(--muted); font-size: 1.1rem; margin-bottom: 28px; font-weight: 600; }
.score-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-bottom: 28px;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}
.score-cell {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 12px;
}
.score-cell .sc-val {
  font-family: 'Orbitron', monospace;
  font-size: 1.6rem;
  font-weight: 900;
  display: block;
  margin-bottom: 4px;
}
.score-cell:nth-child(1) .sc-val { color: #00d4ff; }
.score-cell:nth-child(2) .sc-val { color: var(--correct); }
.score-cell:nth-child(3) .sc-val { color: #0099ff; }
.score-cell .sc-label { color: var(--muted); font-size: 0.8rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
.grade-msg {
  font-family: 'Orbitron', monospace;
  font-size: 1rem;
  color: #00aaff;
  margin-bottom: 28px;
  letter-spacing: 2px;
}
.btn-play-again {
  background: linear-gradient(135deg, #0066cc, #00aaff);
  border: none;
  border-radius: 10px;
  padding: 16px 40px;
  font-family: 'Orbitron', monospace;
  font-size: 0.9rem;
  font-weight: 700;
  color: #000;
  cursor: pointer;
  letter-spacing: 2px;
  transition: all 0.2s;
  box-shadow: 0 0 20px rgba(0,170,255,0.3);
  margin-right: 12px;
}
.btn-play-again:hover { transform: translateY(-2px); box-shadow: 0 0 30px rgba(0,212,255,0.5); }
.btn-topics {
  background: transparent;
  border: 1px solid #00d4ff;
  border-radius: 10px;
  padding: 16px 30px;
  font-family: 'Orbitron', monospace;
  font-size: 0.85rem;
  font-weight: 700;
  color: #00d4ff;
  cursor: pointer;
  letter-spacing: 2px;
  transition: all 0.2s;
}
.btn-topics:hover { background: rgba(0,212,255,0.08); }

/* ── CONFETTI ── */
.confetti-container { position: fixed; inset: 0; pointer-events: none; z-index: 300; overflow: hidden; }
.cp {
  position: absolute;
  top: -20px;
  animation: cpFall linear forwards;
  border-radius: 2px;
}
@keyframes cpFall {
  0%{transform:translateY(0) rotate(0deg);opacity:1}
  100%{transform:translateY(110vh) rotate(720deg);opacity:0}
}

/* ── DATA INSIGHT TAG ── */
.insight-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(0,150,255,0.1);
  border: 1px solid rgba(0,200,255,0.25);
  border-radius: 6px;
  padding: 4px 10px;
  font-family: 'Space Mono', monospace;
  font-size: 0.7rem;
  color: #00d4ff;
  margin-bottom: 14px;
  letter-spacing: 1px;
}

/* ── EduMind Branding — Dark Theme ── */
.edumind-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 24px;
  background: rgba(8,12,20,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(0,212,255,0.15);
  position: sticky;
  top: 0;
  z-index: 50;
  box-shadow: 0 2px 20px rgba(0,0,0,0.4), 0 1px 0 rgba(0,212,255,0.1);
}
.edumind-logo {
  font-family: 'Orbitron', monospace;
  font-size: 1.2rem;
  font-weight: 900;
  letter-spacing: 2px;
  display: flex;
  align-items: center;
  gap: 4px;
}
.edumind-logo .em-edu { color: #00d4ff; text-shadow: 0 0 10px rgba(0,212,255,0.5); }
.edumind-logo .em-mind { color: #ff6b35; text-shadow: 0 0 10px rgba(255,107,53,0.5); }
.edumind-logo .em-icon { font-size: 1rem; }
.edumind-tagline {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  color: #4a6080;
  letter-spacing: 3px;
  text-transform: uppercase;
}
.edumind-badge {
  background: transparent;
  border: 1px solid rgba(0,212,255,0.3);
  color: #00d4ff;
  border-radius: 6px;
  padding: 5px 14px;
  font-family: 'Orbitron', monospace;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  box-shadow: 0 0 10px rgba(0,212,255,0.1), inset 0 0 10px rgba(0,212,255,0.05);
}
.edumind-footer {
  width: 100%;
  padding: 14px 24px;
  background: rgba(8,12,20,0.95);
  backdrop-filter: blur(12px);
  border-top: 1px solid rgba(0,212,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 30px;
  box-shadow: 0 -2px 20px rgba(0,0,0,0.3);
}
.edumind-footer-logo {
  font-family: 'Orbitron', monospace;
  font-size: 0.95rem;
  font-weight: 900;
  letter-spacing: 2px;
}
.edumind-footer-logo .em-edu { color: #00d4ff; }
.edumind-footer-logo .em-mind { color: #ff6b35; }
.edumind-footer-copy {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  color: #4a6080;
  letter-spacing: 1px;
}
.edumind-footer-divider {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: #1e3a5f;
}
body {
  padding: 0 !important;
}
.game-container {
  padding-top: 20px;
}

</style>
</head>
<body>
<header class="edumind-header">
  <div class="edumind-logo-img"><img src="data:image/png;base64," alt="EduMind" style="height:44px;width:auto;object-fit:contain;"></div>
  <div class="edumind-tagline">Created by EduMind</div>
  <div class="edumind-badge">Learning Made Fun</div>
</header>
<div class="orb orb1"></div>
<div class="orb orb2"></div>
<div class="orb orb3"></div>
<div class="confetti-container" id="confetti"></div>
<div class="streak-banner" id="streakBanner">🔥 STREAK BONUS!</div>

<div class="game-container">
  <!-- HEADER -->
