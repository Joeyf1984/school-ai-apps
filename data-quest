function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function startGame(topic) {
  state.topic = topic;
  let pool = [];
  if (topic === 'mixed') {
    pool = [...QUESTIONS.youtube, ...QUESTIONS.f1, ...QUESTIONS.sonic];
  } else {
    pool = [...QUESTIONS[topic]];
  }
  // Repeat shuffled pool to fill 20 questions
  state.questions = [];
  while (state.questions.length < 20) {
    state.questions.push(...shuffle(pool));
  }
  state.questions = state.questions.slice(0, 20);
  state.current = 0;
  state.points = 0;
  state.streak = 0;
  state.bestStreak = 0;
  state.answered = [];
  state.canAnswer = true;

  document.getElementById('topicScreen').style.display = 'none';
  document.getElementById('completeScreen').classList.remove('show');
  document.getElementById('questionScreen').style.display = 'block';
  buildQDots();
  loadQuestion();
}

function buildQDots() {
  const c = document.getElementById('qDots');
  c.innerHTML = '';
  for (let i = 0; i < 20; i++) {
    const d = document.createElement('div');
    d.className = 'q-dot' + (i===0?' active':'');
    d.id = 'qdot'+i;
    c.appendChild(d);
  }
}

function updateQDots() {
  for (let i = 0; i < 20; i++) {
    const d = document.getElementById('qdot'+i);
    if (!d) continue;
    d.className = 'q-dot';
    if (i < state.current) d.classList.add(state.answered[i]==='ok'?'done-ok':'done-bad');
    else if (i === state.current) d.classList.add('active');
  }
}

function updateStats() {
  document.getElementById('pts').textContent = state.points;
  document.getElementById('str').textContent = state.streak + (state.streak >= 2 ? '🔥' : '');
  document.getElementById('prg').textContent = state.current + '/20';
  document.getElementById('progFill').style.width = (state.current / 20 * 100) + '%';
  document.getElementById('qCounter').textContent = `Q${state.current+1} / 20`;
}

