            <div class="bar-label">${b.label}</div>
            <div class="bar-track">
              <div class="bar-fill" style="width:0%;background:${b.color}" data-pct="${(b.val/max*100).toFixed(1)}"></div>
            </div>
            <div class="bar-val">${b.val}</div>
          </div>
        `).join('')}
      </div>
    </div>`;
}

function renderPieChart(data) {
  const total = data.slices.reduce((s,x)=>s+x.val,0);
  let angle = -90;
  const r = 70, cx = 80, cy = 80;
  const paths = data.slices.map(s => {
    const pct = s.val / total;
    const start = angle * Math.PI / 180;
    angle += pct * 360;
    const end = angle * Math.PI / 180;
    const x1 = cx + r * Math.cos(start), y1 = cy + r * Math.sin(start);
    const x2 = cx + r * Math.cos(end), y2 = cy + r * Math.sin(end);
    const large = pct > 0.5 ? 1 : 0;
    return `<path d="M${cx},${cy} L${x1.toFixed(1)},${y1.toFixed(1)} A${r},${r} 0 ${large},1 ${x2.toFixed(1)},${y2.toFixed(1)} Z" fill="${s.color}" stroke="#080c14" stroke-width="2"/>`;
  }).join('');

  return `
    <div class="chart-wrap">
      <div class="chart-title">🥧 ${data.title}</div>
      <div class="pie-wrap">
        <svg class="pie-svg" width="160" height="160" viewBox="0 0 160 160">${paths}</svg>
        <div class="pie-legend">
          ${data.slices.map(s=>`
            <div class="legend-item">
              <div class="legend-dot" style="background:${s.color}"></div>
              <span>${s.label}: <strong>${s.val}%</strong></span>
            </div>
          `).join('')}
        </div>
      </div>
    </div>`;
}

function renderLineChart(data) {
  const max = Math.max(...data.points) * 1.1;
  const min = Math.min(...data.points) * 0.85;
  const W = 600, H = 120, pad = 10;
  const pts = data.points.map((v,i) => {
    const x = pad + (i / (data.points.length-1)) * (W - pad*2);
    const y = H - pad - ((v-min)/(max-min)) * (H - pad*2);
    return [x.toFixed(1), y.toFixed(1)];
  });
  const polyline = pts.map(p=>p.join(',')).join(' ');
  const area = `${pts[0][0]},${H} ` + polyline + ` ${pts[pts.length-1][0]},${H}`;

  return `
    <div class="chart-wrap">
      <div class="chart-title">📈 ${data.title}</div>
      <div class="line-chart-wrap">
        <svg class="line-svg" viewBox="0 0 ${W} ${H+30}" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="lineGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="${data.color}" stop-opacity="0.3"/>
              <stop offset="100%" stop-color="${data.color}" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <polygon points="${area}" fill="url(#lineGrad)"/>
          <polyline points="${polyline}" fill="none" stroke="${data.color}" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
          ${pts.map((p,i)=>`
            <circle cx="${p[0]}" cy="${p[1]}" r="4" fill="${data.color}" stroke="#080c14" stroke-width="1.5"/>
            <text x="${p[0]}" y="${H+22}" text-anchor="middle" font-size="11" fill="#4a6080" font-family="Space Mono,monospace">${data.labels[i]}</text>
            <text x="${p[0]}" y="${parseFloat(p[1])-8}" text-anchor="middle" font-size="10" fill="${data.color}" font-family="Space Mono,monospace">${data.points[i]}</text>
          `).join('')}
        </svg>
      </div>
    </div>`;
}

function loadQuestion() {
  if (state.current >= 20) { showComplete(); return; }
  state.canAnswer = true;
  const q = state.questions[state.current];

  // Topic tag
  const topicNames = {youtube:'📺 YOUTUBERS', f1:'🏎️ FORMULA 1', sonic:'💙 SONIC', mixed:'⚡ MIXED'};
  document.getElementById('topicTag').textContent = topicNames[state.topic] || '⚡ MIXED';
  document.getElementById('insightTag').textContent = q.insight;
  document.getElementById('qTypeBadge').textContent = q.type === 'bar' ? 'BAR CHART' : q.type === 'pie' ? 'PIE CHART' : 'LINE GRAPH';
  document.getElementById('qText').textContent = q.q;

  // Chart
  let chartHTML = '';
  if (q.type === 'bar') chartHTML = renderBarChart(q.chart);
  else if (q.type === 'pie') chartHTML = renderPieChart(q.chart);
  else if (q.type === 'line') chartHTML = renderLineChart(q.chart);
  document.getElementById('chartArea').innerHTML = chartHTML;

  // Animate bars after render
  if (q.type === 'bar') {
    setTimeout(() => {
      document.querySelectorAll('.bar-fill').forEach(b => {
        b.style.width = b.dataset.pct + '%';
      });
    }, 50);
  }

  // Answers
  const grid = document.getElementById('answersGrid');
  grid.innerHTML = '';
  const letters = ['A','B','C','D'];
  q.answers.forEach((ans, i) => {
    const btn = document.createElement('button');
    btn.className = 'ans-btn';
    btn.innerHTML = `<span class="ans-letter">${letters[i]}</span> ${ans}`;
    btn.onclick = () => handleAnswer(btn, i, q);
    grid.appendChild(btn);
  });

  // Feedback
  const fb = document.getElementById('feedbackBar');
  fb.className = 'feedback-bar';
  fb.innerHTML = '';

  updateQDots();
  updateStats();
}

function handleAnswer(btn, idx, q) {
  if (!state.canAnswer) return;
  state.canAnswer = false;
  const allBtns = document.querySelectorAll('.ans-btn');
  allBtns.forEach(b => b.disabled = true);

  const fb = document.getElementById('feedbackBar');

  if (idx === q.correct) {
    btn.classList.add('correct-ans');
    state.answered[state.current] = 'ok';
    state.points += 10 + (state.streak >= 2 ? 5 : 0);
    state.streak++;
    if (state.streak > state.bestStreak) state.bestStreak = state.streak;
    fb.innerHTML = `✅ CORRECT! <span class="fb-detail">${q.explain}</span>`;
    fb.className = 'feedback-bar ok show';
    if (state.streak >= 3) { playStreak(); showStreakBanner(); }
    else playCorrect();
    launchConfetti(6);
    setTimeout(next, 1600);
  } else {
    btn.classList.add('wrong-ans');
    allBtns[q.correct].classList.add('correct-ans');
    state.answered[state.current] = 'bad';
    state.streak = 0;
    fb.innerHTML = `❌ NOT QUITE — <span class="fb-detail">${q.explain}</span>`;
    fb.className = 'feedback-bar bad show';
    playWrong();
    setTimeout(next, 2200);
  }
  updateStats();
}

function next() {
  state.current++;
  if (state.current >= 20) showComplete();
  else loadQuestion();
}

function showStreakBanner() {
  const b = document.getElementById('streakBanner');
  b.textContent = `🔥 ${state.streak}x STREAK! +5 BONUS PTS`;
  b.classList.add('show');
  setTimeout(() => b.classList.remove('show'), 2000);
}

function showComplete() {
  document.getElementById('questionScreen').style.display = 'none';
  const cs = document.getElementById('completeScreen');
  cs.classList.add('show');
  const correct = state.answered.filter(a=>a==='ok').length;
  document.getElementById('finalPts').textContent = state.points;
  document.getElementById('finalCorrect').textContent = `${correct}/20`;
  document.getElementById('finalStreak').textContent = state.bestStreak + '🔥';
  const pct = correct / 20;
  let grade, sub;
  if (pct === 1) { grade = '⭐ S RANK — PERFECT DATA ANALYST!'; sub = 'Flawless. You missed nothing.'; }
  else if (pct >= 0.8) { grade = '🏆 A RANK — EXCELLENT WORK!'; sub = 'Strong analysis skills!'; }
  else if (pct >= 0.6) { grade = '✅ B RANK — SOLID EFFORT!'; sub = 'Good understanding of the data.'; }
  else if (pct >= 0.4) { grade = '📊 C RANK — KEEP PRACTISING!'; sub = 'Review your chart skills and try again.'; }
  else { grade = '💪 D RANK — DON\'T GIVE UP!'; sub = 'Data analysis takes practice. You got this!'; }
  document.getElementById('gradeMsg').textContent = grade;
  document.getElementById('completeSubtitle').textContent = sub;
  launchConfetti(50);
  playComplete();
}

function restartSame() {
  document.getElementById('completeScreen').classList.remove('show');
  startGame(state.topic);
}

function restartToTopics() {
  document.getElementById('questionScreen').style.display = 'none';
  document.getElementById('completeScreen').classList.remove('show');
  document.getElementById('topicScreen').style.display = 'block';
  state = { topic:'', questions:[], current:0, points:0, streak:0, bestStreak:0, answered:[], canAnswer:true };
  updateStatsDirect(0, 0, '0/20');
}

function updateStatsDirect(pts, str, prg) {
  document.getElementById('pts').textContent = pts;
  document.getElementById('str').textContent = str;
  document.getElementById('prg').textContent = prg;
}

function launchConfetti(n) {
  const c = document.getElementById('confetti');
  const cols = ['#00d4ff','#0080ff','#00aaff','#ffffff','#0066cc','#4dd0e1','#00e5ff'];
  for (let i = 0; i < n; i++) {
    const p = document.createElement('div');
    p.className = 'cp';
    p.style.left = Math.random() * 100 + 'vw';
    p.style.background = cols[Math.floor(Math.random()*cols.length)];
    p.style.width = (8+Math.random()*10)+'px';
    p.style.height = (8+Math.random()*10)+'px';
    p.style.borderRadius = Math.random()>0.5?'50%':'2px';
    p.style.animationDuration = (1.5+Math.random()*2.5)+'s';
    p.style.animationDelay = (Math.random()*0.8)+'s';
    c.appendChild(p);
    setTimeout(()=>p.remove(), 4000);
  }
}
